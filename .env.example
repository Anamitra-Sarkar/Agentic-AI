# GROQ_API_KEY: Required for Groq API calls (Server-side only).
GROQ_API_KEY="MY_GROQ_API_KEY"

# OPENROUTER_API_KEY: Required for OpenRouter API calls (Server-side only).
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# NVIDIA_API_KEY: Required for NVIDIA API calls (Server-side only).
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"

# VITE_TAVILY_API_KEY: Required for Tavily API calls (Shared with client).
VITE_TAVILY_API_KEY="MY_TAVILY_API_KEY"
